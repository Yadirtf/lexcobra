# LexCobra API — Variables de entorno
# Copia este archivo como .env y rellena los valores

# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL="postgresql://lexcobra_user:lexcobra_pass@localhost:5432/lexcobra_db"

# ── JWT ────────────────────────────────────────────────────────
# Genera un secreto seguro: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_USE_OPENSSL_RAND_HEX_64"
COOKIE_SECRET="CHANGE_ME_USE_OPENSSL_RAND_HEX_32"

# ── Servidor ───────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Dominio base de la plataforma ─────────────────────────────
BASE_DOMAIN=lexcobra.app
# En desarrollo local puedes usar "localhost"
# BASE_DOMAIN=localhost

# ── Redis (opcional en desarrollo) ────────────────────────────
REDIS_URL="redis://localhost:6379"
